module top(
    input clk,
    input reset,
    output reg [3:0] q
);

reg [3:0] slow_cnt;

always @(posedge clk) begin
    if (reset) begin
        slow_cnt <= 4'd0;
        q        <= 4'd0;
    end
    else begin
        if (slow_cnt == 4'd9) begin
            slow_cnt <= 4'd0;
            q        <= q + 4'd1;   // increment q every 10 cycles
        end
        else begin
            slow_cnt <= slow_cnt + 4'd1;
        end
    end
end

endmodule
