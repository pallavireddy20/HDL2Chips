module top(
    input clk,
    input reset,
    output reg [3:0] q
);
    // Write your code here
    always @(posedge clk)
        begin
            if(reset)
                q<=4'b0;
            else if(q==12)
                q<=4'b1;
            else
                q<=q+4'b1;
        end
endmodule
