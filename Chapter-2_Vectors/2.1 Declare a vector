module top(
    input  [7:0] meera,
    input  [7:0] raj,
    output [7:0] safe,
    output [7:0] watch
);

    wire [7:0] agree;

    consensus c1 (
        .meera(meera),
        .raj(raj),
        .safe(agree)
    );

    alarm a1 (
        .consensus(agree),
        .raj(raj),
        .watch(watch)
    );

    assign safe = agree;

endmodule

module consensus(
    input  [7:0] meera,
    input  [7:0] raj,
    output [7:0] safe
);
    assign safe = meera & raj;
endmodule

module alarm(
    input  [7:0] consensus,
    input  [7:0] raj,
    output [7:0] watch
);
    assign watch = consensus ^ raj;
endmodule
