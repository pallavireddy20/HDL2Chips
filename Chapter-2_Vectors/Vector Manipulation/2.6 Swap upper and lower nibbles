module bit_shuffle (
    input  [3:0] in,
    output [3:0] out
);
    // MSB side (bits 3:2) swaps with LSB side (bits 1:0)
    assign out = {in[1:0], in[3:2]};
endmodule

module top_module (
    input  [3:0] meera,
    input  [3:0] raj,
    output [7:0] scrambled
);
    wire [3:0] meera_shuffled;
    wire [3:0] raj_shuffled;
    
    // Instantiate two bit_shuffle modules
    bit_shuffle meera_shuffle (.in(meera), .out(meera_shuffled));
    bit_shuffle raj_shuffle (.in(raj), .out(raj_shuffled));
    
    // Combine shuffled outputs into scrambled 8-bit result:
    // [7:6] = LSB side of meera_shuffled (bits 1:0)
    // [5:4] = MSB side of raj_shuffled (bits 3:2)
    // [3:2] = MSB side of meera_shuffled (bits 3:2)
    // [1:0] = LSB side of raj_shuffled (bits 1:0)
    assign scrambled = {meera_shuffled[1:0], raj_shuffled[3:2], 
                        meera_shuffled[3:2], raj_shuffled[1:0]};
endmodule
