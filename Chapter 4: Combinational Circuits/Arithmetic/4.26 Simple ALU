module top(
    input [7:0] a,
    input [7:0] b,
    input [1:0] op,
    output reg [7:0] out
);
    // Write your code here
    always @(*) begin
    case(op)
        2'b00: out = a & b;  // AND
        2'b01: out = a | b;  // OR
        2'b10: out = a + b;  // Addition
        2'b11: out = a - b;  // Subtraction
        default: out = 8'b00000000;
    endcase
end
endmodule
