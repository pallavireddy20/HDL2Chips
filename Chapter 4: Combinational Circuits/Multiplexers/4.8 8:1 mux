module top(
    input [2:0] sel,
    input [7:0] in,
    output out
);
    // Write your code here
     assign out = (sel == 3'd0) ? in[0] :
                 (sel == 3'd1) ? in[1] :
                 (sel == 3'd2) ? in[2] :
                 (sel == 3'd3) ? in[3] :
                 (sel == 3'd4) ? in[4] :
                 (sel == 3'd5) ? in[5] :
                 (sel == 3'd6) ? in[6] :
                                 in[7];

endmodule
