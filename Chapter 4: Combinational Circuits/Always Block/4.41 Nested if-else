module top(
    input [1:0] a,
    input [1:0] b,
    output reg out
);
    // Write your code here
    always @(*) begin
    if (a[1] > b[1])
        out = 1'b1;
    else if (a[1] < b[1])
        out = 1'b0;
    else begin
        if (a[0] > b[0])
            out = 1'b1;
        else
            out = 1'b0;
    end
end
                
endmodule
