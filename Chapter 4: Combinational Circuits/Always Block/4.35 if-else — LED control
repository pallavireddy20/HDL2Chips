module top(
    input [1:0] sel,
    output reg [3:0] out
);
    // Write your code here
    always @(*) begin
    if (sel == 2'b00)
        out = 4'b0001;
    else if (sel == 2'b01)
        out = 4'b0010;
    else if (sel == 2'b10)
        out = 4'b0100;
    else
        out = 4'b1000;
    end
endmodule
